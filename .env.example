# ── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
APP_BASE_URL=http://localhost:3000
JWT_SECRET=cambia-esto-por-un-secreto-largo-aleatorio

# ── Base de datos ───────────────────────────────────────────────────────────
# Desarrollo local (docker compose):
DATABASE_URL=postgres://automaint:automaint@localhost:5432/automaint
# Supabase (runtime, pooler puerto 6543):
# DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Para migraciones usar la conexión directa (puerto 5432)
RUN_MIGRATIONS=true

# ── Archivos ────────────────────────────────────────────────────────────────
# local: guarda en UPLOAD_DIR y sirve en /files | supabase: Supabase Storage
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Buckets requeridos en Supabase (públicos): vehicle-photos, receipts, listings, partner-docs

# ── Auth ────────────────────────────────────────────────────────────────────
# true: /auth/oauth/{google,apple} acepta tokens "mock:<email>:<nombre>"
OAUTH_MOCK=true

# ── Jobs ────────────────────────────────────────────────────────────────────
ENABLE_JOBS=true

# ── Integraciones opcionales (sin credenciales = modo log-only) ─────────────
# RESEND_API_KEY=re_...
EMAIL_FROM=AutoMaint <no-reply@automaint.app>

# ── Diagnóstico IA (Google AI Studio, free tier). Sin key = modo mock ───────
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
FREE_DAILY_DIAGNOSTICS=3
FREE_DAILY_LISTING_QUESTIONS=1
